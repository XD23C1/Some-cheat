local function UpdateCrosshairPosition()
    local cam = workspace.CurrentCamera
    if getgenv().crosshair_x and getgenv().crosshair_x["Line"] then
        getgenv().crosshair_x["Line"].To = Vector2.new(((cam.ViewportSize.x / 2) - 0) - CrosshairSettings.Length, (cam.ViewportSize.y / 2) - 0)
        getgenv().crosshair_x["Line"].From = Vector2.new(((cam.ViewportSize.x / 2) - 0) + CrosshairSettings.Length, (cam.ViewportSize.y / 2) - 0)
    end
    if getgenv().crosshair_y and getgenv().crosshair_y["Line"] then
        getgenv().crosshair_y["Line"].To = Vector2.new((cam.ViewportSize.x / 2) - 0, ((cam.ViewportSize.y / 2) - 0) - CrosshairSettings.Length)
        getgenv().crosshair_y["Line"].From = Vector2.new((cam.ViewportSize.x / 2) - 0, ((cam.ViewportSize.y / 2) - 0) + CrosshairSettings.Length)
