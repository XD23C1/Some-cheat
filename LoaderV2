end

local function UpdateCrosshairPosition()
    local cam = workspace.CurrentCamera
    if getgenv().crosshair_x and getgenv().crosshair_x["Line"] then
        getgenv().crosshair_x["Line"].To = Vector2.new(((cam.ViewportSize.x / 2) - 0) - CrosshairSettings.Length, (cam.ViewportSize.y / 2) - 0)
        getgenv().crosshair_x["Line"].From = Vector2.new(((cam.ViewportSize.x / 2) - 0) + CrosshairSettings.Length, (cam.ViewportSize.y / 2) - 0)
    end
    if getgenv().crosshair_y and getgenv().crosshair_y["Line"] then
        getgenv().crosshair_y["Line"].To = Vector2.new((cam.ViewportSize.x / 2) - 0, ((cam.ViewportSize.y / 2) - 0) - CrosshairSettings.Length)
        getgenv().crosshair_y["Line"].From = Vector2.new((cam.ViewportSize.x / 2) - 0, ((cam.ViewportSize.y / 2) - 0) + CrosshairSettings.Length)
    end
end

-- ========== TRIGGERBOT (with whitelist) ==========
RunService.RenderStepped:Connect(function()
    if not TriggerbotEnabled then return end

    local target = mouse.Target
    if not target then return end

    local character = target:FindFirstAncestorWhichIsA("Model") or target.Parent
    
    while character and not character:FindFirstChildOfClass("Humanoid") do
        character = character.Parent
    end

    if not character or not character:FindFirstChildOfClass("Humanoid") then return end

    local humanoid = character:FindFirstChildOfClass("Humanoid")
    local hitPlayer = Players:GetPlayerFromCharacter(character)

    if humanoid.Health <= 0 or not hitPlayer or hitPlayer == LocalPlayer then return end
    
    -- WHITELIST CHECK
    if Whitelist.Enabled and IsWhitelisted(hitPlayer) then return end

    local doShoot = true

    if AliveCheck and humanoid.Health <= 0 then doShoot = false end
    if TeamCheck and hitPlayer.Team == LocalPlayer.Team then doShoot = false end

    local checkPart = character:FindFirstChild(AimPart) 
                   or character:FindFirstChild("Head") 
                   or character:FindFirstChild("HumanoidRootPart")
    if WallCheck and checkPart and not IsVisible(checkPart) then
        doShoot = false
    end

    if doShoot then
        local mousePos = UserInputService:GetMouseLocation()
        local screenPos, onScreen = Camera:WorldToViewportPoint(character.HumanoidRootPart.Position)
        if onScreen then
            local dist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
            if dist > FOVRadius then
                doShoot = false
            end
        end
    end

    if doShoot then
        mouse1press()
        repeat
            RunService.RenderStepped:Wait()
        until not mouse.Target or not (mouse.Target:FindFirstAncestorWhichIsA("Model") or mouse.Target.Parent):FindFirstChildOfClass("Humanoid")
        mouse1release()
    end
end)

