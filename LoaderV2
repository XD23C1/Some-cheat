local function CreateSkeleton()
    local lines = {}
    for i = 1, #r6Bones do
        local line = Drawing.new("Line")
        line.Thickness = 2
        line.Transparency = 1
        lines[i] = line
    end
    return lines
end

local function CreateESP(plr)
    if plr == LocalPlayer or ESPObjects[plr] then return end
    local box = Drawing.new("Square")
    box.Thickness = 2; box.Filled = false; box.Transparency = 1
    local tracer = Drawing.new("Line")
    tracer.Thickness = 1.5; tracer.Transparency = 1
    local name = Drawing.new("Text")
    name.Size = 13; name.Center = true; name.Outline = true; name.Color = Color3.new(1,1,1)
    ESPObjects[plr] = {Box = box, Tracer = tracer, Name = name}
end

local function UpdateChams()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local hl = plr.Character:FindFirstChildOfClass("Highlight")
            if getgenv().ChamsEnabled then
                if not hl then
                    hl = Instance.new("Highlight")
                    hl.Adornee = plr.Character
                    hl.Parent = plr.Character
                end
                hl.FillColor = Rainbow(getgenv().RainbowSpeed)
                hl.OutlineColor = Color3.fromRGB(255, 255, 255)
                hl.FillTransparency = 0.5
                hl.OutlineTransparency = 0
            else
                if hl then hl:Destroy() end
            end
        end
    end
end

local function UpdateESP()
    if not getgenv().ESPEnabled then
        for _, data in pairs(ESPObjects) do
            data.Box.Visible = false
            data.Tracer.Visible = false
            data.Name.Visible = false
        end
        return
    end

    for plr, data in pairs(ESPObjects) do
        local char = plr.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") or not char:FindFirstChild("Head") then
            data.Box.Visible = false; data.Tracer.Visible = false; data.Name.Visible = false
            continue
        end

        local root = char.HumanoidRootPart
        local head = char.Head
        local rootPos = Camera:WorldToViewportPoint(root.Position)
        local headPos = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
        local legPos = Camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3, 0))

        if rootPos.Z < 0 then
            data.Box.Visible = false; data.Tracer.Visible = false; data.Name.Visible = false
            continue
        end

        local rainbowCol = Rainbow(getgenv().RainbowSpeed)
        local height = math.abs(headPos.Y - legPos.Y) * 1.1
        local width = height * 0.55

        data.Box.Size = Vector2.new(width, height)
        data.Box.Position = Vector2.new(rootPos.X - width/2, rootPos.Y - height/2)
        data.Box.Color = rainbowCol
        data.Box.Visible = true

        data.Tracer.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
        data.Tracer.To = Vector2.new(rootPos.X, rootPos.Y)
        data.Tracer.Color = rainbowCol
        data.Tracer.Visible = true

        local dist = math.floor((root.Position - Camera.CFrame.Position).Magnitude)
        data.Name.Text = plr.Name .. " [" .. dist .. "]"
        data.Name.Position = Vector2.new(rootPos.X, data.Box.Position.Y - 20)
        data.Name.Visible = true
    end
end

