-- ========== VISIBILITY CHECK ==========
local function IsVisible(part)
    if not WallCheck then return true end
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {LocalPlayer.Character or {}}
    params.FilterType = Enum.RaycastFilterType.Exclude
    local ray = workspace:Raycast(Camera.CFrame.Position, (part.Position - Camera.CFrame.Position).Unit * 1000, params)
    return not ray or ray.Instance:IsDescendantOf(part.Parent)
end

-- ========== GET CLOSEST PLAYER (with whitelist) ==========
local function GetClosestPlayer()
    local closest, dist = nil, FOVRadius
    local mousePos = UserInputService:GetMouseLocation()
    
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("Humanoid") then
            -- WHITELIST CHECK
            if Whitelist.Enabled and IsWhitelisted(plr) then continue end
            
            if AliveCheck and plr.Character.Humanoid.Health <= 0 then continue end
            if TeamCheck and plr.Team == LocalPlayer.Team then continue end

            local part = plr.Character:FindFirstChild(AimPart)
            if not part then
                part = plr.Character:FindFirstChild("UpperTorso") or plr.Character:FindFirstChild("Head") or plr.Character:FindFirstChild("HumanoidRootPart")
            end
            if part then
                local screen, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local distance = (Vector2.new(screen.X, screen.Y) - mousePos).Magnitude
                    if distance < dist and IsVisible(part) then
                        dist = distance
                        closest = plr.Character
                    end
                end
            end
        end
    end
    return closest
end

local currentConnection = nil

local function StartAimbot()
    if currentConnection then currentConnection:Disconnect() end

    currentConnection = RunService.RenderStepped:Connect(function()
        local mousePos = UserInputService:GetMouseLocation()
        FOVCircle.Position = Vector2.new(mousePos.X, mousePos.Y)
        FOVCircle.Radius = FOVRadius
        
        if FOVRainbow then
            FOVCircle.Color = Rainbow(getgenv().RainbowSpeed)
        else
            FOVCircle.Color = FOVCircleColor
        end
        FOVCircle.Visible = AimEnabled

        if not AimEnabled then return end
        if not UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then return end

        local target = GetClosestPlayer()
        if target then
            local targetPart = target:FindFirstChild(AimPart)
            if not targetPart then
                targetPart = target:FindFirstChild("UpperTorso") or target:FindFirstChild("Head") or target:FindFirstChild("HumanoidRootPart")
            end
            
            if targetPart then
                local targetPos = targetPart.Position
                local currentCFrame = Camera.CFrame
                local targetCFrame = CFrame.lookAt(currentCFrame.Position, targetPos)
                Camera.CFrame = currentCFrame:Lerp(targetCFrame, Smoothing)
            end
        end
    end)
end

