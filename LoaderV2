-- Функция проверки в белом списке
local function IsWhitelisted(player)
    if not Whitelist.Enabled then return false end
    for _, name in ipairs(Whitelist.List) do
        if player.Name:lower() == name:lower() then
            return true
        end
    end
    return false
end

-- Функция для обновления UI списка
local function UpdateWhitelistUI()
    if WhitelistList then
        local text = ""
        for i, name in ipairs(Whitelist.List) do
            text = text .. i .. ". " .. name .. "\n"
        end
        if text == "" then text = "Empty" end
        WhitelistList:Set(text)
    end
end

