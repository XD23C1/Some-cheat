local r6Bones = {
    {"Torso", "Head"}, {"Torso", "Left Arm"}, {"Left Arm", "Left Hand"},
    {"Torso", "Right Arm"}, {"Right Arm", "Right Hand"},
    {"Torso", "Left Leg"}, {"Left Leg", "Left Foot"},
